# Postgres connection. For Medusa use Neon's DIRECT (non-pooled) string;
# locally, a local postgres URL. The `vector` extension must be available.
DATABASE_URL=
DB_NAME=medusa-backend

# Gemini embeddings (Google AI Studio: https://aistudio.google.com/apikey).
# Required for semantic search.
GOOGLE_GENERATIVE_AI_API_KEY=

# Secrets. Generate strong values for production:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

# CORS — comma-separated allowed origins (storefront, admin, auth).
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000,http://localhost:5173
AUTH_CORS=http://localhost:8000,http://localhost:9000,http://localhost:5173

# Optional — Redis (events, cache). Without it Medusa runs in-memory (dev only).
REDIS_URL=

# Optional — transactional email via Resend. Without these, notifications are
# logged locally instead of sent. See DEPLOY.md Part E.
RESEND_API_KEY=
RESEND_FROM=R² Commerce <noreply@example.com>
MEDUSA_BACKEND_URL=http://localhost:9000   # builds the admin password-reset link
STOREFRONT_URL=http://localhost:8000       # builds the customer password-reset link

# Optional — card payments via Stripe. See DEPLOY.md Part F.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
