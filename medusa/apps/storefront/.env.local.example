# Where the Medusa backend is reachable from the storefront server.
MEDUSA_BACKEND_URL=http://localhost:9000

# Publishable API key (scopes the Store API to our sales channel) and the region
# used to resolve prices (USD). Get these from the backend:
#   npm run -w @dtc/backend exec ./src/scripts/setup-store.ts   (prints both)
MEDUSA_PUBLISHABLE_KEY=pk_...
MEDUSA_REGION_ID=reg_...
