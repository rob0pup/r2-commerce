# Where the Medusa backend is reachable from the storefront server.
MEDUSA_BACKEND_URL=http://localhost:9000

# Publishable API key (scopes the Store API to our sales channel) and the region
# used to resolve prices (USD). Get these from the backend:
#   npm run -w @dtc/backend exec ./src/scripts/setup-store.ts   (prints both)
MEDUSA_PUBLISHABLE_KEY=pk_...
MEDUSA_REGION_ID=reg_...

# Optional — Google Analytics 4 measurement id. Analytics stays off if unset.
# (Vercel Web Analytics needs no key and is always on when deployed to Vercel.)
NEXT_PUBLIC_GA_ID=

# Optional — Stripe publishable key. When set, checkout shows the Stripe card
# form; otherwise it uses the manual payment provider. See DEPLOY.md Part F.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional — demo the R² Lookup semantic-search widget (a separate SaaS). Set to
# a Lookup store id whose catalog is indexed; the search widget then appears on
# the storefront. Leave unset to hide it.
NEXT_PUBLIC_LOOKUP_STORE=
